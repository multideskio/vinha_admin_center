#!/usr/bin/env sh

# Validação de commit: FORMAT → LINT → TYPECHECK
# Cada etapa deve passar para o commit ser aceito

echo "🔍 Verificando formatação, lint e tipos..."

# 1. FORMAT + LINT (via lint-staged nos arquivos staged)
npx lint-staged

# 2. TYPECHECK (projeto inteiro - garante consistência de tipos)
echo "📝 Verificando tipos TypeScript..."
npx tsc --noEmit
